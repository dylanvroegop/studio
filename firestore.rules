
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of the resource being accessed
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Rules for the 'quotes' collection
    match /quotes/{quoteId} {
      allow read, get: if isSignedIn() && (resource.data.userId == request.auth.uid || !('userId' in resource.data));
      allow list: if isSignedIn() && (request.query.where.userId == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || !('userId' in request.resource.data));
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || !('userId' in resource.data));
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || !('userId' in resource.data));

      // Subcollection: Quote Notes
      // We check the PARENT quote's ownership to allow access to these notes.
      // This allows the existing queries (which don't filter by userId) to work safely.
      match /quote_notes/{noteId} {
         allow read, write: if isSignedIn() && get(/databases/$(database)/documents/quotes/$(quoteId)).data.userId == request.auth.uid;
      }
    }
    
    // Rules for the 'notes' (Personal Notes) collection
    match /notes/{noteId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // Rules for the 'materials' collection
    match /materials/{materialId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isOwner(resource.data.userId);
      allow write: if isSignedIn() && isOwner(request.resource.data.userId);
    }

    // Rules for the 'businesses' collection
    match /businesses/{businessId} {
      allow create: if isSignedIn() && isOwner(businessId);
      allow get, update, delete: if isSignedIn() && isOwner(businessId);
    }

    // Rules for the 'presets' collection
    match /presets/{presetId} {
        allow read, get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Rules for the 'users' collection (User Settings)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Rules for the 'counters' collection (Quote Numbers)
    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }
    
    // Rules for the 'clients' collection (Client directory)
    // Code uses 'clients' collection, NOT 'klanten'
    match /clients/{clientId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
