{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the HoutOfferte application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "createdAt"
      ]
    },
    "Quote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Quote",
      "type": "object",
      "description": "Represents a quote created in the HoutOfferte application.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N Quote)"
        },
        "status": {
          "type": "string",
          "description": "The status of the quote (e.g., 'Concept', 'In behandeling')"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp indicating when the quote was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp indicating when the quote was last updated."
        },
        "clientType": {
          "type": "string",
          "enum": [
            "Particulier",
            "Zakelijk"
          ],
          "description": "The type of client."
        },
        "companyName": {
          "type": "string",
          "description": "The client's company name (if applicable)."
        },
        "contactPerson": {
          "type": "string",
          "description": "The contact person at the company (if applicable)."
        },
        "firstName": {
          "type": "string",
          "description": "The client's first name."
        },
        "lastName": {
          "type": "string",
          "description": "The client's last name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The client's email address."
        },
        "phone": {
          "type": "string",
          "description": "The client's phone number."
        },
        "billingStreet": {
          "type": "string",
          "description": "The client's billing street."
        },
        "billingHouseNumber": {
          "type": "string",
          "description": "The client's billing house number."
        },
        "billingPostcode": {
          "type": "string",
          "description": "The client's billing postal code."
        },
        "billingCity": {
          "type": "string",
          "description": "The client's billing city."
        },
        "hasDifferentProjectAddress": {
          "type": "boolean",
          "description": "Whether the project address is different from the billing address."
        },
        "projectStreet": {
          "type": "string",
          "description": "The project's street (if different)."
        },
        "projectHouseNumber": {
          "type": "string",
          "description": "The project's house number (if different)."
        },
        "projectPostcode": {
          "type": "string",
          "description": "The project's postal code (if different)."
        },
        "projectCity": {
          "type": "string",
          "description": "The project's city (if different)."
        },
        "shortDescription": {
          "type": "string",
          "description": "A short description of the work to be done."
        }
      },
      "required": [
        "userId",
        "status",
        "createdAt",
        "updatedAt",
        "clientType",
        "firstName",
        "lastName",
        "email",
        "phone",
        "billingStreet",
        "billingHouseNumber",
        "billingPostcode",
        "billingCity",
        "hasDifferentProjectAddress",
        "shortDescription"
      ]
    },
    "Material": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Material",
      "type": "object",
      "description": "Represents a material with its properties, specific to a user.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this material."
        },
        "categorie": {
          "type": "string",
          "description": "The category of the material (e.g., hout, isolatie, plaat)."
        },
        "materiaalnaam": {
          "type": "string",
          "description": "The name of the material."
        },
        "prijs": {
          "type": "number",
          "description": "The price of the material."
        },
        "eenheid": {
          "type": "string",
          "description": "The unit of measurement for the material (e.g., m1, m2, st, pak)."
        },
        "leverancier": {
          "type": "string",
          "description": "The supplier of the material."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp indicating when the material was last updated."
        }
      },
      "required": [
        "userId",
        "categorie",
        "materiaalnaam",
        "prijs",
        "eenheid",
        "leverancier",
        "updatedAt"
      ]
    },
    "Business": {
      "title": "Business",
      "type": "object",
      "description": "Represents business information for a registered user.",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The business contact email."
        },
        "bedrijfsnaam": {
          "type": "string",
          "description": "The name of the business."
        },
        "kvkNummer": {
          "type": "string",
          "description": "The KVK (Chamber of Commerce) number."
        },
        "btwNummer": {
          "type": "string",
          "description": "The BTW (VAT) number (optional)."
        },
        "telefoon": {
          "type": "string",
          "description": "The business phone number (optional)."
        },
        "rol": {
          "type": "string",
          "enum": ["Aannemer", "Timmerman", "Bouwbedrijf"],
          "description": "The user's role in the company."
        },
        "offertesPerMaand": {
          "type": "string",
          "enum": ["0–10", "10–30", "30+"],
          "description": "The estimated number of quotes per month."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the business was registered."
        }
      },
      "required": [
        "email",
        "bedrijfsnaam",
        "kvkNummer",
        "rol",
        "offertesPerMaand",
        "createdAt"
      ]
    },
    "Preset": {
      "title": "Preset",
      "type": "object",
      "description": "Stores user-defined material and setting presets for a specific job type.",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this preset."
        },
        "jobType": {
          "type": "string",
          "description": "The type of job this preset applies to (e.g., 'hsb-wand')."
        },
        "name": {
          "type": "string",
          "description": "The user-defined name for the preset."
        },
        "isDefault": {
          "type": "boolean",
          "description": "Whether this preset should be applied by default."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "slots": {
          "type": "object",
          "description": "A map of slot keys to the chosen material ID.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "collapsedSections": {
          "type": "object",
          "description": "A map of slot keys to a boolean indicating if the section is collapsed.",
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "gipsLagen": {
            "type": "number",
            "description": "The number of gips layers for this preset, if applicable."
        }
      },
      "required": ["userId", "jobType", "name", "createdAt", "slots"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "quotes": {
      "schema": {
        "$ref": "#/entities/Quote"
      },
      "description": "Stores all quote documents for all users."
    },
    "materials": {
      "schema": {
        "$ref": "#/entities/Material"
      },
      "description": "Stores all material documents for all users."
    },
    "businesses": {
      "schema": {
        "$ref": "#/entities/Business"
      },
      "description": "Stores business information for each user (UID is document ID)."
    },
    "presets": {
      "schema": {
        "$ref": "#/entities/Preset"
      },
      "description": "Stores user-defined presets for job materials and settings."
    }
  }
}
